# 复制本文件为 .env 并填入你自己的密钥（.env 不会被提交到 Git）
# 密钥在阿里云 RAM 控制台 -> 用户 -> 创建 AccessKey 时获得

OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=你的bucket名称

# === ClickHouse 连接 ===
# 本地 Docker 默认即下面这组；切到云上改成阿里云控制台给的地址/密码
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=ch_local_pwd
CLICKHOUSE_DB=price_index
# 云 ClickHouse 若使用 HTTPS，把 SECURE 设为 true，端口通常按控制台给的填写
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY=true
